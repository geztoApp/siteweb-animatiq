# Copy this file to .env (never commit .env itself) and fill in the real
# values, then pass them as environment variables to the app (Easypanel: app
# settings → Environment).

# Optional, defaults to 80 (matches the port Easypanel already routes to).
PORT=80

# Resend (https://resend.com) sends a notification email for every form
# submission, on top of the always-on data/submissions.log. Leave
# RESEND_API_KEY unset to disable email entirely — submissions still get
# logged and stay visible at /admin/submissions.
RESEND_API_KEY=re_...

# Must be on a domain verified in your Resend account, or the sandbox
# address below (which only delivers to the email your Resend account is
# registered with).
RESEND_FROM=onboarding@resend.dev

# Where submission notifications are sent.
RESEND_TO=gezto.app@gmail.com
