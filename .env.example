# Copy this file to .env (never commit .env itself) and fill in the real
# values before running `docker compose up`.

# Required by chat-server.
OPENAI_API_KEY=sk-...

# Shared by all three services. Set this to your real site domain in
# production (comma-separated if you need more than one), e.g.:
# ALLOWED_ORIGIN=https://animatiq.ch,https://www.animatiq.ch
ALLOWED_ORIGIN=*

# Optional, defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini
