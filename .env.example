# Copy this file to .env (never commit .env itself) and fill in the real
# values, then pass them as environment variables to the app (Easypanel: app
# settings → Environment).

# Required for the chat assistant (/api/chat).
OPENAI_API_KEY=sk-...

# Optional, defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional, defaults to 8080. Easypanel usually sets this for you.
PORT=8080
